{
  "$schema": "https://schema.tauri.app/capability/2",
  "identifier": "default",
  "description": "Default app capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/python-backend",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-app-read",
    "fs:allow-app-write"
  ]
}
